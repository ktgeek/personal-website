---
layout: layouts/base.njk
title: Resume
description: Professional experience
---

<div class="flex items-baseline justify-between mb-10">
  <h1 class="text-3xl font-bold tracking-tight text-gray-900">Resume</h1>
  <a href="/assets/Keith-Garner-Resume.pdf" class="text-sm text-gray-500 hover:text-gray-900 hover:underline transition-colors" target="_blank" rel="noopener noreferrer">(PDF version)</a>
</div>

<div class="space-y-10">
  {% for job in resume %}
    <div class="border-l-2 border-gray-200 pl-6">
      <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">{{ job.role }}</h2>
          <p class="text-gray-500">
            {% if job.url %}
              <a href="{{ job.url }}" class="hover:underline hover:text-gray-900 transition-colors" target="_blank" rel="noopener noreferrer">{{ job.company }}</a>
            {% else %}
              {{ job.company }}
            {% endif %}
          </p>
        </div>
        <span class="text-sm text-gray-400 shrink-0">{{ job.dates }}</span>
      </div>
      <p class="text-gray-600 text-sm mb-3">{{ job.description }}</p>
      {% if job.highlights %}
        <ul class="space-y-1">
          {% for item in job.highlights %}
            <li class="flex gap-2 text-sm text-gray-600">
              <span class="text-gray-300 select-none">—</span>
              <span>{{ item }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  {% endfor %}
</div>
