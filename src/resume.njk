---
layout: layouts/base.njk
title: Resume
description: Professional experience
---

<div class="flex items-baseline justify-between mb-10">
  <h1 class="font-pixel text-sm text-arcade-yellow glow-yellow leading-loose">Resume</h1>
  <a href="/assets/Keith-Garner-Resume.pdf" class="font-pixel text-[9px] text-arcade-dim hover:text-arcade-yellow transition-colors" target="_blank" rel="noopener noreferrer">[PDF]</a>
</div>

<div class="border-l-2 border-arcade-yellow pl-6 mb-10">
  <h2 class="font-pixel text-[10px] text-arcade-yellow mb-3 leading-loose">Executive Summary</h2>
  <p class="text-xs text-arcade-dim leading-relaxed">{{ resume.summary }}</p>
</div>

<div class="space-y-10">
  {% for job in resume.jobs %}
    <div class="border-l-2 border-arcade-magenta pl-6">
      <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
        <div>
          <h2 class="font-pixel text-[10px] text-arcade-cyan mb-1 leading-loose">{{ job.role }}</h2>
          <p class="text-sm text-arcade-green">
            {% if job.url %}
              <a href="{{ job.url }}" class="hover:text-arcade-yellow hover:underline transition-colors" target="_blank" rel="noopener noreferrer">{{ job.company }}</a>
            {% else %}
              {{ job.company }}
            {% endif %}
          </p>
        </div>
        <span class="font-pixel text-[9px] text-arcade-dim shrink-0 leading-loose">{{ job.dates }}</span>
      </div>
      <p class="text-xs text-arcade-dim mb-3 leading-relaxed">{{ job.description }}</p>
      {% if job.highlights %}
        <ul class="space-y-1">
          {% for item in job.highlights %}
            <li class="flex gap-2 text-xs text-arcade-dim">
              <span class="text-arcade-magenta select-none shrink-0">&gt;</span>
              <span>{{ item }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  {% endfor %}
</div>

<div class="border-l-2 border-arcade-cyan pl-6 mt-10">
  <h2 class="font-pixel text-[10px] text-arcade-cyan mb-3 leading-loose">Publications</h2>
  <ul class="space-y-1">
    {% for pub in resume.publications %}
      <li class="flex gap-2 text-xs text-arcade-dim">
        <span class="text-arcade-cyan select-none shrink-0">&gt;</span>
        <span>{{ pub }}</span>
      </li>
    {% endfor %}
  </ul>
</div>
