---
layout: layouts/base.njk
title: Blog
description: Writing on software, tools, and ideas
tags: []
eleventyExcludeFromCollections: true
---

<h1 class="font-pixel text-sm text-arcade-yellow glow-yellow mb-10 leading-loose">Blog</h1>

{% set posts = collections.post | reverse %}
{% if posts.length %}
  <ul class="space-y-8">
    {% for post in posts %}
      <li class="border-l-2 border-arcade-border pl-6 hover:border-arcade-cyan transition-colors">
        <article>
          <a href="{{ post.url }}" class="group block">
            <h2 class="font-pixel text-[10px] text-arcade-cyan group-hover:text-arcade-yellow group-hover:glow-yellow transition-colors mb-3 leading-loose">
              {{ post.data.title }}
            </h2>
          </a>
          <div class="flex items-center gap-2 font-pixel text-[9px] mb-2 leading-loose">
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
          </div>
          {% if post.data.description %}
            <p class="text-xs mb-2 leading-relaxed">{{ post.data.description }}</p>
          {% endif %}
          {% set userTags = post.data.tags | reject("equalto", "post") | list %}
          {% if userTags | length %}
            <div class="flex flex-wrap gap-2 mt-2">
              {% for tag in userTags %}
                <a href="/blog/tags/{{ tag | slug }}/"
                   class="font-pixel text-[8px] border border-arcade-magenta text-arcade-magenta px-2 py-1 hover:bg-arcade-magenta hover:text-arcade-bg transition-colors leading-none">{{ tag }}</a>
              {% endfor %}
            </div>
          {% endif %}
        </article>
      </li>
    {% endfor %}
  </ul>
{% else %}
  <p class="font-pixel text-[10px] leading-loose">No posts yet. Check back soon.</p>
{% endif %}
