---
layout: layouts/base.njk
title: Blog
description: Writing on software, tools, and ideas
tags: []
---

<h1 class="text-3xl font-bold tracking-tight text-gray-900 mb-10">Blog</h1>

{% set posts = collections.post | reverse %}
{% if posts.length %}
  <ul class="space-y-8">
    {% for post in posts %}
      <li>
        <article>
          <a href="{{ post.url }}" class="group block">
            <h2 class="text-lg font-semibold text-gray-900 group-hover:underline mb-1">
              {{ post.data.title }}
            </h2>
          </a>
          <div class="flex items-center gap-2 text-sm text-gray-400 mb-2">
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
          </div>
          {% if post.data.description %}
            <p class="text-sm text-gray-600">{{ post.data.description }}</p>
          {% endif %}
          {% set userTags = post.data.tags | reject("equalto", "post") | list %}
          {% if userTags | length %}
            <div class="flex flex-wrap gap-2 mt-2">
              {% for tag in userTags %}
                <a href="/blog/tags/{{ tag | slug }}/"
                   class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded hover:bg-gray-200 transition-colors">{{ tag }}</a>
              {% endfor %}
            </div>
          {% endif %}
        </article>
      </li>
    {% endfor %}
  </ul>
{% else %}
  <p class="text-gray-500">No posts yet. Check back soon.</p>
{% endif %}
