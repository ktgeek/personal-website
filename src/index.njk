<!-- Hero -->
<section class="mb-16">
  <div class="flex flex-col sm:flex-row sm:items-center gap-8">
    <div class="flex-1">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 mb-4">{{ site.name }}</h1>
      <p class="text-xl text-gray-500 mb-6">{{ site.tagline }}</p>
      <p class="text-gray-600 leading-relaxed max-w-xl">
        Welcome to my corner of the internet. I build software, write about what I learn,
        and work on side projects that scratch itches. This site is where I collect that work.
      </p>
    </div>
    <div class="shrink-0 flex justify-center">
      <img src="/assets/images/keith.jpg"
           alt="Keith T. Garner"
           class="w-40 h-40 rounded-full object-cover shadow-md">
    </div>
  </div>
</section>

<!-- Section cards -->
<section>
  <div class="grid sm:grid-cols-2 gap-4">

    <a href="/about/" class="group block p-5 border border-gray-200 rounded-lg hover:border-gray-400 hover:shadow-sm transition-all">
      <h2 class="font-semibold text-gray-900 mb-1 group-hover:underline">About</h2>
      <p class="text-sm text-gray-500">Background, interests, and how I got here.</p>
    </a>

    <a href="/work/" class="group block p-5 border border-gray-200 rounded-lg hover:border-gray-400 hover:shadow-sm transition-all">
      <h2 class="font-semibold text-gray-900 mb-1 group-hover:underline">Work</h2>
      <p class="text-sm text-gray-500">My job history and professional experience.</p>
    </a>

    <a href="/projects/" class="group block p-5 border border-gray-200 rounded-lg hover:border-gray-400 hover:shadow-sm transition-all">
      <h2 class="font-semibold text-gray-900 mb-1 group-hover:underline">Projects</h2>
      <p class="text-sm text-gray-500">Side projects and open-source work I've shipped.</p>
    </a>

    <a href="/blog/" class="group block p-5 border border-gray-200 rounded-lg hover:border-gray-400 hover:shadow-sm transition-all">
      <h2 class="font-semibold text-gray-900 mb-1 group-hover:underline">Blog</h2>
      <p class="text-sm text-gray-500">Writing on software, tools, and ideas.</p>
