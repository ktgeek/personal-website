<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}" />
  <link rel="stylesheet" href="/assets/css/output.css" />
</head>
<body class="h-full flex flex-col bg-white text-gray-900 font-sans">

  <!-- Nav -->
  <header class="border-b border-gray-200">
    <nav class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="font-semibold text-lg tracking-tight hover:text-gray-600 transition-colors">
        {{ site.name }}
      </a>

      <!-- Desktop nav -->
      <ul class="hidden sm:flex items-center gap-6 text-sm font-medium">
        {% for link in site.nav %}
          {% if link.url !== "/" %}
            <li>
              <a href="{{ link.url }}"
                 class="{% if page.url == link.url %}text-gray-900 border-b border-gray-900{% else %}text-gray-500 hover:text-gray-900{% endif %} transition-colors pb-0.5">
                {{ link.label }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      <!-- Mobile hamburger -->
      <button id="menu-btn" class="sm:hidden p-2 rounded text-gray-500 hover:text-gray-900 hover:bg-gray-100 transition-colors" aria-label="Toggle menu">
        <svg id="icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden sm:hidden border-t border-gray-100">
      <ul class="max-w-3xl mx-auto px-4 py-3 flex flex-col gap-1">
        {% for link in site.nav %}
          {% if link.url !== "/" %}
            <li>
              <a href="{{ link.url }}"
                 class="block py-2 px-2 rounded text-sm font-medium {% if page.url == link.url %}text-gray-900 bg-gray-50{% else %}text-gray-600 hover:text-gray-900 hover:bg-gray-50{% endif %} transition-colors">
                {{ link.label }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </header>

  <!-- Main content -->
  <main class="flex-1 max-w-3xl mx-auto w-full px-4 py-12">
    {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-200">
    <div class="max-w-3xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-gray-500">
      <p>© {{ site.name }}</p>
      <ul class="flex items-center gap-4">
        {% for link in site.social %}
          <li>
            <a href="{{ link.url }}" class="hover:text-gray-900 transition-colors" target="_blank" rel="noopener noreferrer">
              {{ link.label }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      iconOpen.classList.toggle('hidden', !isOpen);
      iconClose.classList.toggle('hidden', isOpen);
    });
  </script>
</body>
</html>
