---
layout: layouts/base.njk
---

<article>
  <header class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 mb-3">{{ title }}</h1>
    <div class="flex items-center gap-3 text-sm text-gray-500">
      <time datetime="{{ date | htmlDateString }}">
        {{ date | readableDate }}
      </time>
      {% if description %}
        <span>·</span>
        <span>{{ description }}</span>
      {% endif %}
    </div>
  </header>

  <div class="prose prose-gray max-w-none
    prose-headings:font-semibold prose-headings:tracking-tight
    prose-a:text-gray-900 prose-a:underline prose-a:underline-offset-2
    prose-code:bg-gray-100 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono
    prose-pre:bg-gray-900 prose-pre:text-gray-100">
    {{ content | safe }}
  </div>

  <div class="mt-12 pt-6 border-t border-gray-200">
    <a href="/blog/" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">← All posts</a>
  </div>
</article>
