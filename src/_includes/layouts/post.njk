---
layout: layouts/base.njk
breadcrumbParent:
  label: Blog
  url: /blog/
---

<article>
  <header class="mb-10">
    <h1 class="font-pixel text-xs text-arcade-yellow glow-yellow mb-4 leading-loose">{{ title }}</h1>
    <div class="flex flex-col gap-1 font-pixel text-[9px] leading-loose">
      <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      {% if description %}
        <p class="text-[8px] leading-relaxed max-w-prose line-clamp-2">{{ description }}</p>
      {% endif %}
    </div>
    {% set userTags = tags | reject("equalto", "post") | list %}
    {% if userTags | length %}
      <div class="flex flex-wrap gap-2 mt-3">
        {% for tag in userTags %}
          <a href="/blog/tags/{{ tag | slug }}/"
             class="font-pixel text-[8px] border border-arcade-magenta text-arcade-magenta px-2 py-1 hover:bg-arcade-magenta hover:text-arcade-bg transition-colors leading-none">{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}
  </header>

  <div class="prose prose-arcade max-w-none
    prose-headings:font-pixel prose-headings:leading-loose
    [&_h2]:text-[12px] [&_h2]:mt-8 [&_h2]:mb-4
    [&_h3]:text-[10px] [&_h3]:mt-6 [&_h3]:mb-3 [&_h3]:text-arcade-green
    prose-a:text-arcade-green prose-a:no-underline hover:prose-a:text-arcade-yellow
    prose-strong:text-arcade-yellow
    prose-code:text-arcade-yellow prose-code:bg-arcade-surface prose-code:px-1 prose-code:py-0.5 prose-code:font-mono prose-code:text-sm
    [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-inherit">
    {{ content | safe }}
  </div>

  <div class="mt-12 pt-6 border-t-2 border-arcade-border">
    <a href="/blog/" class="font-pixel text-[9px] text-arcade-green hover:text-arcade-yellow transition-colors">&lt; All posts</a>
  </div>
</article>
