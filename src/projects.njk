---
layout: layouts/base.njk
title: Projects
description: Side projects and open-source work
---

<h1 class="font-pixel text-sm text-arcade-yellow glow-yellow mb-10 leading-loose">Projects</h1>

<div class="grid sm:grid-cols-2 gap-5">
  {% for project in projects %}
    <div class="pixel-box bg-arcade-surface p-5 flex flex-col hover:border-arcade-cyan transition-all">
      <div class="flex-1">
        <h2 class="font-pixel text-[10px] text-arcade-cyan mb-3 leading-loose">
          {% if project.url %}
            <a href="{{ project.url }}" class="hover:text-arcade-yellow hover:glow-yellow transition-colors" target="_blank" rel="noopener noreferrer">{{ project.name }}</a>
          {% else %}
            {{ project.name }}
          {% endif %}
        </h2>
        <p class="text-xs mb-4 leading-relaxed">{{ project.description }}</p>
      </div>
      {% if project.tech %}
        <div class="flex flex-wrap gap-1.5">
          {% for tag in project.tech %}
            <span class="font-pixel text-[8px] border border-arcade-magenta text-arcade-magenta px-2 py-1 leading-none">{{ tag }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% endfor %}
</div>
